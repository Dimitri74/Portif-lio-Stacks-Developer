{
  "info": {
    "_postman_id": "9f013f87-d8ff-4ccb-b84a-6f18fdcd5f93",
    "name": "Java MongoDB - Formulario API",
    "description": "Collection completa para testar CRUD de formularios e consulta de CEP via ViaCEP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Buscar Endereco por CEP",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/formularios/cep/{{cep}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "formularios",
            "cep",
            "{{cep}}"
          ]
        },
        "description": "Consulta endereco no ViaCEP sem salvar no MongoDB."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var data = pm.response.json();",
              "pm.test('Retorna campos basicos de endereco', function () {",
              "    pm.expect(data).to.have.property('cep');",
              "    pm.expect(data).to.have.property('logradouro');",
              "    pm.expect(data).to.have.property('localidade');",
              "    pm.expect(data).to.have.property('uf');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Criar Formulario Principal",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Marcus Dimitri\",\n  \"email\": \"{{emailPrincipal}}\",\n  \"cep\": \"{{cep}}\",\n  \"complemento\": \"Apto 42\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/formularios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "formularios"
          ]
        },
        "description": "Cria formulario principal, enriquece endereco via ViaCEP e salva no MongoDB."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var data = pm.response.json();",
              "pm.test('Retorna id do formulario criado', function () {",
              "    pm.expect(data).to.have.property('id');",
              "    pm.expect(data.id).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Retorna email normalizado', function () {",
              "    pm.expect(data.email).to.eql(pm.collectionVariables.get('emailPrincipal'));",
              "});",
              "",
              "pm.collectionVariables.set('id', data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Negativo Criar Formulario com Email Duplicado (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Outro Usuario\",\n  \"email\": \"{{emailPrincipal}}\",\n  \"cep\": \"{{cep}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/formularios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "formularios"
          ]
        },
        "description": "Valida a regra de um formulario por email."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 409', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "var data = pm.response.json();",
              "pm.test('Retorna payload amigavel de erro', function () {",
              "    pm.expect(data).to.have.property('timestamp');",
              "    pm.expect(data).to.have.property('status', 409);",
              "    pm.expect(data).to.have.property('error', 'Conflict');",
              "    pm.expect(data).to.have.property('trace', 'Email ja cadastrado');",
              "    pm.expect(data.trace).to.not.contain('org.springframework');",
              "});"
            ]
          }
        }
      ]
    },
